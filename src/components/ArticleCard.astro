---
import { formatDate, articleHeadline } from '../lib/content';
import type { Article } from '../lib/types';

interface Props {
  article: Article;
  featured?: boolean;
  horizontal?: boolean;  // hero layout: side-by-side image + text
}

const { article, featured = false, horizontal = false } = Astro.props;
const url = `/${article.category}/${article.slug}/`;
const headline = articleHeadline(article);
---
<article class:list={['article-card', { featured, horizontal }]}>
  <div class="card-body">
    <a href={`/${article.category}/`} class="card-category badge">
      {article.categoryLabel}
    </a>

    <h2 class="card-title">
      <a href={url}>{headline}</a>
    </h2>

    <p class="card-excerpt">{article.excerpt}</p>

    <div class="card-meta">
      <span>{formatDate(article.updatedAt)}</span>
      <span aria-hidden="true">·</span>
      <span>{article.products.length} picks</span>
    </div>
  </div>
</article>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .article-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .card-img-wrap {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bg-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.5rem;
    transition: transform 0.3s;
  }

  .article-card:hover .card-img-wrap img {
    transform: scale(1.03);
  }

  .card-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .card-category {
    align-self: flex-start;
    text-decoration: none !important;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }

  .card-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .card-title a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .card-excerpt {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .card-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.775rem;
    color: var(--color-text-muted);
    margin-top: auto;
    padding-top: 0.5rem;
  }

  /* Featured card: bigger image, larger title */
  .article-card.featured .card-img-wrap {
    aspect-ratio: 16 / 8;
  }

  .article-card.featured .card-title {
    font-size: 1.35rem;
  }

  .article-card.featured .card-excerpt {
    -webkit-line-clamp: 4;
    font-size: 0.9rem;
  }

  /* Horizontal variant (hero layout) */
  .article-card.horizontal {
    flex-direction: row;
    align-items: stretch;
  }

  .article-card.horizontal .card-img-wrap {
    width: 240px;
    flex-shrink: 0;
    aspect-ratio: auto;
  }

  .article-card.horizontal .card-body {
    flex: 1;
    padding: 1.25rem 1.5rem;
  }

  .article-card.horizontal .card-excerpt {
    -webkit-line-clamp: 2;
  }

  @media (max-width: 600px) {
    .article-card.horizontal { flex-direction: column; }
    .article-card.horizontal .card-img-wrap { width: 100%; aspect-ratio: 16/9; }
  }
</style>
