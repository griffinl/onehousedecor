---
import StarRating from './StarRating.astro';
import type { Product } from '../lib/types';

interface Props {
  product: Product;
}

const { product } = Astro.props;

const rankBadge = (rank: number) => {
  const defaults: Record<number, string> = {
    1: 'Best Overall', 2: 'Runner Up', 3: 'Best Value',
  };
  return defaults[rank] ?? 'Also Great';
};
// Badge is the keyword-rich section heading (H2); always present.
const badgeText = product.badge ?? product.bestFor ?? rankBadge(product.rank);
---
<article class="review-card" id={`product-${product.rank}`}>

  <header class="review-header">
    <span class="review-rank">#{product.rank}</span>
    <h2 class="review-badge">{badgeText}</h2>
  </header>

  <div class="review-body">
    <a href={product.affiliateUrl} target="_blank" rel="nofollow noopener" class="review-img-link">
      <img
        src={product.image}
        alt={product.label}
        loading="lazy"
        decoding="async"
        width="260"
        height="260"
      />
    </a>

    <div class="review-content">
      <h3 class="review-product-title">
        <a href={product.affiliateUrl} target="_blank" rel="nofollow noopener">{product.label}</a>
      </h3>

      <StarRating rating={product.rating} />

      {product.specs.length > 0 && (
        <ul class="specs-list" role="list">
          {product.specs.map((s) => (
            <li><strong>{s.label}</strong>: {s.value}</li>
          ))}
        </ul>
      )}

      <a
        href={product.affiliateUrl}
        target="_blank"
        rel="nofollow noopener"
        class="btn btn-primary check-price-btn"
      >
        Check Price
      </a>
    </div>
  </div>

  <div class="pros-cons">
    <div class="pros">
      <h4 class="pc-heading pros-heading">Pros</h4>
      <ul role="list">
        {product.pros.map((p) => <li>{p}</li>)}
      </ul>
    </div>
    <div class="cons">
      <h4 class="pc-heading cons-heading">Cons</h4>
      <ul role="list">
        {product.cons.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </div>

  {product.review && (
    <div class="review-text rich-text" set:html={product.review} />
  )}

  <div class="review-verdict">
    <strong>Bottom Line:</strong> {product.verdict}
  </div>

</article>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.title,
  image: product.image,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: product.rating,
    reviewCount: product.reviewCount,
    bestRating: 5,
    worstRating: 1,
  },
  offers: {
    '@type': 'Offer',
    price: product.price.replace(/[^0-9.]/g, ''),
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: product.affiliateUrl,
  },
})} />

<style>
  .review-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: #fff;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  /* ── Header ── */
  .review-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 1.5rem;
    background: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
  }

  .review-rank {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .review-badge {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-primary);
    background: rgba(45,74,62,0.08);
    padding: 0.2em 0.65em;
    border-radius: 2em;
  }

  /* ── Body ── */
  .review-body {
    display: grid;
    grid-template-columns: 38% 62%;
    align-items: center;
    padding: 1.75rem 2rem;
    gap: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .review-img-link {
    display: block;
  }

  .review-img-link img {
    display: block;
    width: 100%;
    max-height: 240px;
    height: auto;
    object-fit: contain;
  }

  .review-content {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .review-product-title {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text);
    margin: 0;
  }

  .review-product-title a {
    color: inherit;
    text-decoration: none;
  }

  .review-product-title a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  /* ── Specs ── */
  .specs-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .specs-list li {
    font-size: 0.875rem;
    line-height: 1.45;
    padding-left: 1.1em;
    position: relative;
    color: var(--color-text);
  }

  .specs-list li::before {
    content: '●';
    position: absolute;
    left: 0;
    top: 0.25em;
    font-size: 0.5em;
    color: var(--color-accent);
  }

  .specs-list li strong {
    font-weight: 600;
  }

  /* ── CTA ── */
  .check-price-btn {
    font-size: 0.9rem;
    padding: 0.65em 2em;
    align-self: flex-start;
  }

  /* ── Pros / Cons ── */
  .pros-cons {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .pros, .cons {
    padding: 1rem 1.5rem;
  }

  .pros { border-right: 1px solid var(--color-border); }

  .pc-heading {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.6rem;
  }

  .pros-heading { color: var(--color-pro); }
  .cons-heading { color: var(--color-con); }

  .pros ul, .cons ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .pros li, .cons li {
    font-size: 0.85rem;
    line-height: 1.5;
    padding-left: 1.2em;
    position: relative;
  }

  .pros li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-pro);
    font-weight: 700;
  }

  .cons li::before {
    content: '✗';
    position: absolute;
    left: 0;
    color: var(--color-con);
    font-weight: 700;
  }

  /* ── Review text ── */
  .review-text {
    padding: 1.25rem 1.5rem;
    font-size: 0.925rem;
    border-top: 1px solid var(--color-border);
    line-height: 1.75;
  }

  /* ── Verdict ── */
  .review-verdict {
    padding: 0.875rem 1.5rem;
    background: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
    font-size: 0.875rem;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  }

  .review-verdict strong {
    font-weight: 700;
    color: var(--color-primary);
  }

  /* ── Responsive ── */
  @media (max-width: 680px) {
    .review-body {
      grid-template-columns: 1fr;
      padding: 1.25rem;
    }
    .review-img-link {
      max-width: 200px;
      margin: 0 auto;
    }
    .pros-cons { grid-template-columns: 1fr; }
    .pros { border-right: none; border-bottom: 1px solid var(--color-border); }
  }
</style>
