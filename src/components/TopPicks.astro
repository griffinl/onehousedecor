---
import type { Product } from '../lib/types';

interface Props {
  products: Product[];
}

const { products } = Astro.props;
const top = products.slice(0, Math.min(products.length, 5));

const rankBadge = (rank: number) => {
  const defaults: Record<number, string> = {
    1: 'Best Overall',
    2: 'Runner Up',
    3: 'Best Value',
    4: 'Also Great',
    5: 'Also Great',
  };
  return defaults[rank] ?? `#${rank} Pick`;
};
---
<aside class="top-picks" aria-label="Quick picks">
  <h2 class="top-picks-heading">Our Top Picks</h2>
  <ol class="picks-list" role="list">
    {top.map((p) => (
      <li class="pick-card">
        <div class="pick-img-cell">
          <a href={p.affiliateUrl} target="_blank" rel="nofollow noopener">
          <img src={p.image} alt={p.label} loading="lazy" />
        </a>
        </div>
        <div class="pick-info">
          <span class="pick-badge">{p.badge ?? p.bestFor ?? rankBadge(p.rank)}</span>
          <span class="pick-name">{p.label}</span>
          <span class="pick-verdict">{p.verdict}</span>
          <a
            href={p.affiliateUrl}
            target="_blank"
            rel="nofollow noopener"
            class="pick-cta"
          >Check Latest Price →</a>
        </div>
      </li>
    ))}
  </ol>
</aside>

<style>
  .top-picks {
    margin: 2rem 0;
  }

  .top-picks-heading {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .picks-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pick-card {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1rem;
    align-items: start;
    padding: 1rem 1.25rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: box-shadow 0.15s;
  }

  .pick-card:hover {
    box-shadow: var(--shadow-sm);
  }

  .pick-img-cell {
    width: 80px;
    height: 80px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pick-img-cell img {
    display: block;
    width: 80px;
    height: 80px;
    max-width: 80px !important;
    object-fit: contain;
  }

  .pick-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
    padding-top: 0.1rem;
  }

  .pick-badge {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .pick-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .pick-verdict {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 0.1rem;
  }

  .pick-cta {
    font-size: 0.875rem;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
    margin-top: 0.3rem;
    align-self: flex-start;
  }

  .pick-cta:hover { text-decoration: underline; }

  @media (max-width: 480px) {
    .pick-card { grid-template-columns: 1fr; }
    .pick-img-cell { display: none; }
  }
</style>
