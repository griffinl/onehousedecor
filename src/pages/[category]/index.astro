---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getAllArticles, getArticlesByCategory } from '../../lib/content';
import { siteConfig } from '../../../site.config';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  const articles = getAllArticles();
  const categories = [...new Set(articles.map((a) => a.category))];
  return categories.map((slug) => {
    const articles = getArticlesByCategory(slug);
    const label = articles[0]?.categoryLabel ?? slug;
    return { params: { category: slug }, props: { label, articles } };
  });
};

const { category } = Astro.params;
const { label, articles } = Astro.props as { label: string; articles: typeof getAllArticles extends () => infer T ? T : never };
---
<BaseLayout
  title={`${label} Reviews`}
  description={`Expert-tested ${label.toLowerCase()} product reviews. We analyze thousands of customer reviews to find the best picks for your home.`}
>
  <div class="container page-top">
    <Breadcrumb crumbs={[{ label, href: `/${category}/` }]} />

    <header class="category-header">
      <h1 class="category-title">{label} Reviews</h1>
      <p class="category-desc">
        We analyze thousands of real customer reviews and product data to surface
        the best {label.toLowerCase()} picks — so you can buy with confidence.
      </p>
    </header>

    <div class="articles-grid">
      {articles.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>

    {articles.length === 0 && (
      <p class="empty">No articles yet in this category. Check back soon.</p>
    )}
  </div>
</BaseLayout>

<style>
  .page-top { padding-top: 1.5rem; padding-bottom: 4rem; }

  .category-header {
    padding: 1.5rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .category-title {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    margin-bottom: 0.6rem;
  }

  .category-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 600px;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .empty {
    color: var(--color-text-muted);
    padding: 3rem 0;
  }

  @media (max-width: 900px) { .articles-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .articles-grid { grid-template-columns: 1fr; } }
</style>
