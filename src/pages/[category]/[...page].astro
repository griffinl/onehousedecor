---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getAllArticles, getArticlesByCategory } from '../../lib/content';
import type { GetStaticPaths, Page } from 'astro';
import type { Article } from '../../lib/types';

export const getStaticPaths: GetStaticPaths = ({ paginate }) => {
  const categories = [...new Set(getAllArticles().map((a) => a.category))];
  return categories.flatMap((slug) => {
    const articles = getArticlesByCategory(slug);
    const label = articles[0]?.categoryLabel ?? slug;
    return paginate(articles, {
      params: { category: slug },
      props: { label },
      pageSize: 24,
    });
  });
};

const { category } = Astro.params;
const { page, label } = Astro.props as { page: Page<Article>; label: string };

const title =
  page.currentPage === 1
    ? `${label} Reviews`
    : `${label} Reviews – Page ${page.currentPage}`;
---
<BaseLayout
  title={title}
  description={`Expert-tested ${label.toLowerCase()} product reviews. We analyze thousands of customer reviews to find the best picks for your home.`}
>
  <div class="container page-top">
    <Breadcrumb crumbs={[{ label, href: `/${category}/` }]} />

    <header class="category-header">
      <h1 class="category-title">{label} Reviews</h1>
      <p class="category-desc">
        We analyze thousands of real customer reviews and product data to surface
        the best {label.toLowerCase()} picks — so you can buy with confidence.
      </p>
    </header>

    <div class="articles-grid">
      {page.data.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>

    {page.data.length === 0 && (
      <p class="empty">No articles yet in this category. Check back soon.</p>
    )}

    {page.lastPage > 1 && (
      <nav class="pagination" aria-label="Pagination">
        {page.url.prev ? (
          <a href={page.url.prev} class="page-btn" rel="prev">← Previous</a>
        ) : (
          <span class="page-btn disabled" aria-disabled="true">← Previous</span>
        )}

        <span class="page-status">Page {page.currentPage} of {page.lastPage}</span>

        {page.url.next ? (
          <a href={page.url.next} class="page-btn" rel="next">Next →</a>
        ) : (
          <span class="page-btn disabled" aria-disabled="true">Next →</span>
        )}
      </nav>
    )}
  </div>
</BaseLayout>

<style>
  .page-top { padding-top: 1.5rem; padding-bottom: 4rem; }

  .category-header {
    padding: 1.5rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .category-title {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    margin-bottom: 0.6rem;
  }

  .category-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 600px;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .empty {
    color: var(--color-text-muted);
    padding: 3rem 0;
  }

  /* ── Pagination ── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .page-btn {
    display: inline-block;
    padding: 0.5em 1.1em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    background: #fff;
    text-decoration: none !important;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .page-btn:hover {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: #fff;
  }

  .page-btn.disabled {
    color: var(--color-text-muted);
    opacity: 0.45;
    pointer-events: none;
  }

  .page-status {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) { .articles-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) {
    .articles-grid { grid-template-columns: 1fr; }
    .pagination { gap: 0.75rem; }
  }
</style>
